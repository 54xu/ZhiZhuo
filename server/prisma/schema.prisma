// 致卓收银 - 数据库Schema
// V1 核心表（17张）+ feature_flag表
// 所有表含 store_id 为多门店预留
// 预留 V2/V3 nullable 字段

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 门店基础 ====================

model Store {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  address       String?   @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  businessHours String?   @db.VarChar(50) @map("business_hours")
  // V3预留：连锁集团
  chainGroupId  Int?      @map("chain_group_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  employees     Employee[]
  zones         Zone[]
  rooms         Room[]
  serviceCategories ServiceCategory[]
  services      Service[]
  members       Member[]
  orders        Order[]
  schedules     Schedule[]
  commissionRules CommissionRule[]
  rechargePlans RechargePlan[]
  featureFlags  FeatureFlag[]
  operationLogs OperationLog[]

  @@map("store")
}

// 功能开关表（V1核心基础设施）
model FeatureFlag {
  id        Int     @id @default(autoincrement())
  storeId   Int     @map("store_id")
  flagKey   String  @db.VarChar(50) @map("flag_key")
  enabled   Boolean @default(false)
  config    String? @db.Text // JSON配置
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store     Store   @relation(fields: [storeId], references: [id])

  @@unique([storeId, flagKey], name: "storeId_flagKey")
  @@map("feature_flag")
}

// ==================== 员工管理 ====================

model Employee {
  id          Int       @id @default(autoincrement())
  storeId     Int       @map("store_id")
  name        String    @db.VarChar(50)
  employeeNo  String    @db.VarChar(20) @map("employee_no")
  phone       String    @db.VarChar(20)
  role        String    @db.VarChar(20) // admin / cashier / technician
  wxOpenid    String?   @db.VarChar(100) @map("wx_openid")
  skills      String?   @db.Text @map("skills") // JSON: 擅长项目ID列表
  status      String    @default("active") @db.VarChar(20) // active / inactive
  hireDate    DateTime? @map("hire_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  store       Store     @relation(fields: [storeId], references: [id])
  schedules   Schedule[]
  commissionRecords CommissionRecord[]
  orderItems  OrderItem[]
  cashieredOrders Order[] @relation("CashierOrders")
  operationLogs OperationLog[]

  @@unique([storeId, employeeNo])
  @@map("employee")
}

// ==================== 区域与房台 ====================

model Zone {
  id        Int     @id @default(autoincrement())
  storeId   Int     @map("store_id")
  name      String  @db.VarChar(50)
  sortOrder Int     @default(0) @map("sort_order")
  status    String  @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store     Store   @relation(fields: [storeId], references: [id])
  rooms     Room[]

  @@map("zone")
}

model Room {
  id            Int     @id @default(autoincrement())
  storeId       Int     @map("store_id")
  zoneId        Int     @map("zone_id")
  name          String  @db.VarChar(50)
  capacity      Int     @default(1)
  currentStatus String  @default("idle") @db.VarChar(20) @map("current_status")
  // idle / in_use / pending_clean / disabled
  sortOrder     Int     @default(0) @map("sort_order")
  status        String  @default("active") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  store         Store   @relation(fields: [storeId], references: [id])
  zone          Zone    @relation(fields: [zoneId], references: [id])
  orders        Order[]

  @@map("room")
}

// ==================== 服务项目 ====================

model ServiceCategory {
  id        Int     @id @default(autoincrement())
  storeId   Int     @map("store_id")
  name      String  @db.VarChar(50)
  sortOrder Int     @default(0) @map("sort_order")
  status    String  @default("active") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store     Store   @relation(fields: [storeId], references: [id])
  services  Service[]

  @@map("service_category")
}

model Service {
  id              Int     @id @default(autoincrement())
  storeId         Int     @map("store_id")
  categoryId      Int     @map("category_id")
  name            String  @db.VarChar(100)
  duration        Int     // 服务时长（分钟）
  price           Decimal @db.Decimal(10, 2)
  memberPrice     Decimal? @db.Decimal(10, 2) @map("member_price")
  description     String? @db.Text
  sortOrder       Int     @default(0) @map("sort_order")
  status          String  @default("active") @db.VarChar(20)
  // V2预留：积分
  pointsEarnRatio Decimal? @db.Decimal(5, 2) @map("points_earn_ratio")
  // V3预留：等级价格 JSON {"level_1": 100, "level_2": 90}
  levelPrices     String?  @db.Text @map("level_prices")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store           Store   @relation(fields: [storeId], references: [id])
  category        ServiceCategory @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  commissionRules CommissionRule[]
  visitCardAccounts VisitCardAccount[]

  @@map("service")
}

// ==================== 会员管理 ====================

model Member {
  id              Int       @id @default(autoincrement())
  storeId         Int       @map("store_id")
  cardNo          String    @db.VarChar(20) @map("card_no")
  phone           String    @db.VarChar(20)
  name            String?   @db.VarChar(50)
  gender          String?   @db.VarChar(10) // male / female / unknown
  birthday        DateTime? @db.Date
  balance         Decimal   @default(0) @db.Decimal(10, 2) // 总余额
  realBalance     Decimal   @default(0) @db.Decimal(10, 2) @map("real_balance") // 实充余额
  giftBalance     Decimal   @default(0) @db.Decimal(10, 2) @map("gift_balance") // 赠送余额
  remark          String?   @db.Text
  status          String    @default("active") @db.VarChar(20)
  lastVisitAt     DateTime? @map("last_visit_at")
  // V2预留
  points          Int?      @default(0) // 积分余额
  qrCode          String?   @db.VarChar(255) @map("qr_code")
  parentMemberId  Int?      @map("parent_member_id") // 子卡关联主卡
  // V3预留
  levelId         Int?      @map("level_id")
  securityPwdHash String?   @db.VarChar(100) @map("security_pwd_hash")
  // 万能扩展字段
  extraData       String?   @db.Text @map("extra_data") // JSON
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  store           Store     @relation(fields: [storeId], references: [id])
  orders          Order[]
  visitCardAccounts VisitCardAccount[]
  rechargeRecords RechargeRecord[]

  @@unique([storeId, phone])
  @@unique([storeId, cardNo])
  @@map("member")
}

model VisitCardAccount {
  id              Int     @id @default(autoincrement())
  memberId        Int     @map("member_id")
  serviceId       Int     @map("service_id")
  totalCount      Int     @map("total_count")
  usedCount       Int     @default(0) @map("used_count")
  remainingCount  Int     @map("remaining_count")
  sourcePlanId    Int?    @map("source_plan_id")
  expiredAt       DateTime? @map("expired_at")
  createdAt       DateTime @default(now()) @map("created_at")

  member          Member  @relation(fields: [memberId], references: [id])
  service         Service @relation(fields: [serviceId], references: [id])

  @@map("visit_card_account")
}

// ==================== 订单管理 ====================

model Order {
  id              Int       @id @default(autoincrement())
  storeId         Int       @map("store_id")
  orderNo         String    @db.VarChar(30) @map("order_no")
  roomId          Int       @map("room_id")
  memberId        Int?      @map("member_id") // 散客为null
  customerName    String?   @db.VarChar(50) @map("customer_name")
  customerPhone   String?   @db.VarChar(20) @map("customer_phone")
  orderStatus     String    @default("pending") @db.VarChar(20) @map("order_status")
  // pending / in_progress / completed / cancelled / refunded
  totalAmount     Decimal   @default(0) @db.Decimal(10, 2) @map("total_amount")
  discountAmount  Decimal   @default(0) @db.Decimal(10, 2) @map("discount_amount")
  actualAmount    Decimal   @default(0) @db.Decimal(10, 2) @map("actual_amount")
  cashierId       Int       @map("cashier_id")
  remark          String?   @db.Text
  startTime       DateTime? @map("start_time")
  endTime         DateTime? @map("end_time")
  // V2预留
  couponId        Int?      @map("coupon_id")
  couponDiscount  Decimal?  @db.Decimal(10, 2) @map("coupon_discount")
  pointsUsed      Int?      @map("points_used")
  pointsDiscount  Decimal?  @db.Decimal(10, 2) @map("points_discount")
  splitGroupId    Int?      @map("split_group_id")
  // V3预留
  levelDiscount   Decimal?  @db.Decimal(10, 2) @map("level_discount")
  // 万能扩展字段
  extraData       String?   @db.Text @map("extra_data") // JSON
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  store           Store     @relation(fields: [storeId], references: [id])
  room            Room      @relation(fields: [roomId], references: [id])
  member          Member?   @relation(fields: [memberId], references: [id])
  cashier         Employee  @relation("CashierOrders", fields: [cashierId], references: [id])
  orderItems      OrderItem[]
  payments        Payment[]
  commissionRecords CommissionRecord[]

  @@unique([storeId, orderNo])
  @@map("order")
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int     @map("order_id")
  serviceId     Int     @map("service_id")
  technicianId  Int     @map("technician_id")
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(10, 2) @map("unit_price") // 下单时快照
  subtotal      Decimal @db.Decimal(10, 2)
  isVisitCard   Boolean @default(false) @map("is_visit_card")
  visitCardId   Int?    @map("visit_card_id")
  remark        String? @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  order         Order   @relation(fields: [orderId], references: [id])
  service       Service @relation(fields: [serviceId], references: [id])
  technician    Employee @relation(fields: [technicianId], references: [id])

  @@map("order_item")
}

// ==================== 支付记录 ====================

model Payment {
  id              Int     @id @default(autoincrement())
  orderId         Int?    @map("order_id")
  rechargeId      Int?    @map("recharge_id")
  paymentType     String  @db.VarChar(30) @map("payment_type")
  // cash / wechat / member_balance / visit_card / combined (VARCHAR便于扩展)
  amount          Decimal @db.Decimal(10, 2)
  wechatTradeNo   String? @db.VarChar(50) @map("wechat_trade_no")
  status          String  @default("pending") @db.VarChar(20)
  // pending / success / failed / refunded
  operatorId      Int     @map("operator_id")
  // V3预留
  installmentPlanId Int?  @map("installment_plan_id")
  createdAt       DateTime @default(now()) @map("created_at")

  order           Order?  @relation(fields: [orderId], references: [id])

  @@map("payment")
}

// ==================== 充值管理 ====================

model RechargePlan {
  id          Int     @id @default(autoincrement())
  storeId     Int     @map("store_id")
  planType    String  @db.VarChar(20) @map("plan_type") // amount / visit
  name        String  @db.VarChar(100)
  payAmount   Decimal @db.Decimal(10, 2) @map("pay_amount")
  giftAmount  Decimal @default(0) @db.Decimal(10, 2) @map("gift_amount")
  serviceId   Int?    @map("service_id") // 次卡充值用
  buyCount    Int?    @map("buy_count")
  giftCount   Int?    @map("gift_count")
  sortOrder   Int     @default(0) @map("sort_order")
  status      String  @default("active") @db.VarChar(20)
  // V2预留
  giftPoints  Int?    @map("gift_points") // 充值送积分
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store       Store   @relation(fields: [storeId], references: [id])

  @@map("recharge_plan")
}

model RechargeRecord {
  id            Int     @id @default(autoincrement())
  storeId       Int     @map("store_id")
  memberId      Int     @map("member_id")
  planId        Int     @map("plan_id")
  planType      String  @db.VarChar(20) @map("plan_type")
  payAmount     Decimal @db.Decimal(10, 2) @map("pay_amount")
  giftAmount    Decimal @default(0) @db.Decimal(10, 2) @map("gift_amount")
  totalAmount   Decimal @db.Decimal(10, 2) @map("total_amount")
  paymentMethod String  @db.VarChar(30) @map("payment_method")
  wechatTradeNo String? @db.VarChar(50) @map("wechat_trade_no")
  operatorId    Int     @map("operator_id")
  remark        String? @db.Text
  // V2预留
  earnedPoints  Int?    @map("earned_points")
  createdAt     DateTime @default(now()) @map("created_at")

  member        Member  @relation(fields: [memberId], references: [id])

  @@map("recharge_record")
}

// ==================== 排班管理 ====================

model Schedule {
  id            Int     @id @default(autoincrement())
  storeId       Int     @map("store_id")
  technicianId  Int     @map("technician_id")
  scheduleDate  DateTime @db.Date @map("schedule_date")
  shiftStart    String  @db.VarChar(10) @map("shift_start") // "10:00"
  shiftEnd      String  @db.VarChar(10) @map("shift_end")   // "22:00"
  rotationOrder Int     @default(0) @map("rotation_order")
  status        String  @default("scheduled") @db.VarChar(20)
  // scheduled / on_duty / off_duty / leave
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  store         Store    @relation(fields: [storeId], references: [id])
  technician    Employee @relation(fields: [technicianId], references: [id])

  @@unique([storeId, technicianId, scheduleDate])
  @@map("schedule")
}

// ==================== 提成管理 ====================

model CommissionRule {
  id              Int     @id @default(autoincrement())
  storeId         Int     @map("store_id")
  serviceId       Int     @map("service_id")
  technicianId    Int?    @map("technician_id") // null=适用所有技师
  commissionType  String  @db.VarChar(20) @map("commission_type") // fixed / percentage
  commissionValue Decimal @db.Decimal(10, 2) @map("commission_value")
  status          String  @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store           Store   @relation(fields: [storeId], references: [id])
  service         Service @relation(fields: [serviceId], references: [id])

  @@map("commission_rule")
}

model CommissionRecord {
  id               Int     @id @default(autoincrement())
  storeId          Int     @map("store_id")
  technicianId     Int     @map("technician_id")
  orderId          Int     @map("order_id")
  orderItemId      Int     @map("order_item_id")
  serviceId        Int     @map("service_id")
  serviceAmount    Decimal @db.Decimal(10, 2) @map("service_amount")
  commissionAmount Decimal @db.Decimal(10, 2) @map("commission_amount")
  commissionDate   DateTime @db.Date @map("commission_date")
  status           String  @default("normal") @db.VarChar(20) // normal / reversed
  createdAt        DateTime @default(now()) @map("created_at")

  technician       Employee @relation(fields: [technicianId], references: [id])
  order            Order    @relation(fields: [orderId], references: [id])

  @@map("commission_record")
}

// ==================== 操作日志 ====================

model OperationLog {
  id          Int     @id @default(autoincrement())
  storeId     Int     @map("store_id")
  operatorId  Int     @map("operator_id")
  action      String  @db.VarChar(50) // refund / price_modify / delete 等
  targetType  String  @db.VarChar(50) @map("target_type") // order / member / service 等
  targetId    Int     @map("target_id")
  detail      String? @db.Text // JSON: 变更前后数据
  createdAt   DateTime @default(now()) @map("created_at")

  store       Store    @relation(fields: [storeId], references: [id])
  operator    Employee @relation(fields: [operatorId], references: [id])

  @@map("operation_log")
}
